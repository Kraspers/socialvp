        const img = document.getElementById('story-media');
        const vid = document.getElementById('story-video');
        clearInterval(storyInterval);
        document.querySelectorAll('.story-progress-fill').forEach((f,i) => f.style.width = i < currentMediaIndex ? '100%' : '0%');
        // Show text overlay
        const textOverlay = document.getElementById('story-text-overlay');
        const textContent = document.getElementById('story-text-content');
        textOverlay.classList.remove('expanded');
        if (s.text && s.text.trim()) {
            textContent.textContent = s.text;
            textOverlay.style.display = 'flex';
        } else {
            textOverlay.style.display = 'none';
        }
        if (s.type === 'image') {
            img.src = s.src; img.style.display = 'block'; vid.style.display = 'none';
            try { vid.pause(); } catch(e){} vid.removeAttribute('src'); try { vid.load(); } catch(e){}
            let p = 0;
            storyInterval = setInterval(() => { p += 2; document.querySelectorAll('.story-progress-fill')[currentMediaIndex].style.width = p+'%'; if(p>=100) nextStory(stories); }, 100);
        } else {
            img.style.display = 'none';
            vid.style.display = 'block';
            vid.pause();
            vid.ontimeupdate = null;
            vid.onended = null;
            vid.oncanplay = null;
            vid.removeAttribute('src');
            vid.load();
            vid.setAttribute('playsinline', '');
            vid.setAttribute('webkit-playsinline', '');
            vid.muted = true;
            vid.src = s.src;
            const capturedIndex = currentMediaIndex;
            vid.oncanplay = () => {
                vid.oncanplay = null;
                vid.play().catch(()=>{});
            };
            vid.load();
            vid.ontimeupdate = () => {
                if (vid.duration) document.querySelectorAll('.story-progress-fill')[capturedIndex].style.width = (vid.currentTime/vid.duration*100)+'%';
            };
            vid.onended = () => nextStory(stories);
        }
        // Check if text overflows (needs expand button)
        requestAnimationFrame(() => {
            const span = document.getElementById('story-text-content');
            const overlay = document.getElementById('story-text-overlay');
            if (span && span.scrollHeight > span.clientHeight + 2) {
                overlay.classList.add('story-text-overflow');
            } else {
                overlay.classList.remove('story-text-overflow');
            }
        });
    }
