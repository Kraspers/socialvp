            <div class="ep-fields">
                <div class="ep-field">
                    <div class="ep-label">Имя</div>
                    <input class="ep-input" id="ep-name" type="text" placeholder="Ваше имя" value="Ваше Имя">
                </div>
                <div class="ep-field">
                    <div class="ep-label">Юзернейм</div>
                    <div style="position:relative;display:flex;align-items:center;">
                        <span style="position:absolute;left:10px;color:rgba(255,255,255,0.45);pointer-events:none;z-index:1;display:flex;align-items:center;top:50%;transform:translateY(-50%);"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="rgba(150,150,160,0.85)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/></svg></span>
                        <input class="ep-input" id="ep-username" type="text" placeholder="username" value="username" style="padding-left:36px;" autocorrect="off" autocapitalize="off" spellcheck="false" oninput="this.value=this.value.replace(/[^a-zA-Z0-9_.-]/g,'')">
                    </div>
                </div>
                <div class="ep-field">
                    <div class="ep-label">Описание</div>
                    <textarea class="ep-input ep-textarea" id="ep-bio" placeholder="Расскажите о себе...">Здесь ваше описание профиля. Расскажите о себе что-нибудь интересное! #впизде</textarea>
