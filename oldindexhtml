    <div class="crop-canvas-wrap" id="crop-canvas-wrap">
        <canvas class="crop-canvas" id="crop-canvas" width="320" height="180"></canvas>
    </div>
    <div class="crop-zoom">
        <label>Масштаб</label>
        <input type="range" id="crop-zoom-range" min="1" max="3" step="0.01" value="1" oninput="updateCropZoom(this.value)">
    </div>
    <div class="crop-hint">Перетащите для позиционирования</div>
    <div class="crop-actions">
        <button class="crop-btn cancel" onclick="closeCropModal()">Отмена</button>
        <button class="crop-btn confirm" onclick="confirmCrop()">Применить</button>
    </div>
</div>
<input type="file" id="ep-file-input" accept="image/*" style="display:none" onchange="onFileSelected(event)">

<!-- Fullscreen Photo Viewer -->
<div class="photo-viewer" id="photo-viewer">
    <button class="photo-viewer-close" onclick="closePhotoViewer()"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    <span class="photo-viewer-counter" id="pv-counter"></span>
    <button class="photo-viewer-prev" id="pv-prev" onclick="pvNav(-1)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
    <div id="pv-content" style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;padding:60px 70px;box-sizing:border-box;"></div>
    <button class="photo-viewer-next" id="pv-next" onclick="pvNav(1)"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>
</div>
<script>
    // ===== POSTS =====
    const samplePosts = [
        { id: 1, author: "Artem", username: "@overdork", avatar: "А", text: "Пока илья новки создаёт вирус и убивает людей, ВП идёт к успеху💪", time: "Только что", likes: 24, reposts: 5, comments: 8, liked: false, reposted: false },
        { id: 2, author: "Подсосок", username: "@podsosok", avatar: "П", text: "Продристань", time: "4 часа назад", likes: 156, reposts: 23, comments: 34, liked: true, reposted: false },
        { id: 3, author: "Дмитрий", username: "@dmitry", avatar: "Д", text: "Кто-нибудь ещё думает, что #впизде — это лучший микроблог года? 🔥", time: "6 часов назад", likes: 89, reposts: 12, comments: 45, liked: false, reposted: false },
        { id: 4, author: "Катя", username: "@katya_photo", avatar: "К", text: "Sunset vibes 🌅 Сегодня поймала идеальный момент! @alex_dev что скажешь?", time: "8 часов назад", likes: 234, reposts: 45, comments: 67, liked: true, reposted: true }
    ];
    let posts = [...samplePosts];

    function formatPostText(text) {
        return text.replace(/#(\w+)/g, '<span class="hashtag">#$1</span>').replace(/@(\w+)/g, '<span class="mention">@$1</span>');
    }

    function renderPostMedia(mediaArr) {
        const n = mediaArr.length;
        const items = mediaArr.map(m => {
            if (m.type === 'video') {
                return `<div class="post-media-item"><video src="${m.src}" muted playsinline></video><div class="post-media-play"><svg width="36" height="36" viewBox="0 0 24 24" fill="white"><circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.4)"/><polygon points="10,8 18,12 10,16" fill="white"/></svg></div></div>`;
            }
            return `<div class="post-media-item"><img src="${m.src}" alt=""></div>`;
        }).join('');
        return `<div class="post-media-grid count-${n}">${items}</div>`;
    }

    function renderPosts() {
        const feed = document.getElementById('feed');
        feed.innerHTML = '';
        posts.forEach(post => {
            const el = document.createElement('div');
            el.className = 'post';
            el.dataset.id = post.id;
            el.innerHTML = `
                <div class="post-header">
                    <div class="avatar" style="${post.avatarUrl ? 'padding:0;overflow:hidden;' : ''}">${post.avatarUrl ? '<img src="' + post.avatarUrl + '" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">' : post.avatar}</div>
                    <div class="post-content">
                        <div class="post-author">
                            <span class="author-name">${post.author}</span>
                            <span class="author-username">${post.username}</span>
                            <span class="post-time">· ${post.time}</span>
                        </div>
                        <div class="post-text">${formatPostText(post.text)}</div>
                        ${post.media && post.media.length ? renderPostMedia(post.media) : ''}
                        <div class="post-actions">
                            <button class="action-btn ${post.liked?'liked':''}" data-action="like" data-id="${post.id}">
                                <svg class="action-icon" viewBox="0 0 24 24" fill="${post.liked?'currentColor':'none'}" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                                <span>${post.likes}</span>
                            </button>
                            <button class="action-btn ${post.reposted?'reposted':''}" data-action="repost" data-id="${post.id}">
                                <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"></polyline><path d="M3 11V9a4 4 0 0 1 4-4h14"></path><polyline points="7 23 3 19 7 15"></polyline><path d="M21 13v2a4 4 0 0 1-4 4H3"></path></svg>
                                <span>${post.reposts}</span>
                            </button>
                            <button class="action-btn" data-action="comment" data-id="${post.id}">
                                <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                                <span>${post.comments}</span>
                            </button>
                            <button class="action-btn" data-action="share" data-id="${post.id}">
                                <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                            </button>
                        </div>
                    </div>
                </div>`;
            el.addEventListener('click', e => { if (!e.target.closest('.action-btn')) openPostModal(post); });
            feed.appendChild(el);
        });
    }

    // ===== POST MODAL =====
    const postModal = document.getElementById('post-modal');
    const modalPostContainer = document.getElementById('modal-post-container');
    const commentInput = document.getElementById('comment-input');
    const commentSubmit = document.getElementById('comment-submit');
    const commentsList = document.getElementById('comments-list');
    let currentPostId = null;
    const postComments = {};

    function openPostModal(post) {
        currentPostId = post.id;
        modalPostContainer.innerHTML = `
            <div class="post">
                <div class="post-header">
                    <div class="avatar" style="${post.avatarUrl ? 'padding:0;overflow:hidden;' : ''}">${post.avatarUrl ? '<img src="' + post.avatarUrl + '" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">' : post.avatar}</div>
                    <div class="post-content">
                        <div class="post-author">
                            <span class="author-name">${post.author}</span>
                            <span class="author-username">${post.username}</span>
                            <span class="post-time">· ${post.time}</span>
                        </div>
                        <div class="post-text" style="font-size:18px;line-height:1.4;">${formatPostText(post.text)}</div>
                        ${post.media && post.media.length ? renderPostMedia(post.media) : ''}
                        <div class="post-actions">
                            <button class="action-btn ${post.liked?'liked':''}" data-action="like" data-id="${post.id}">
                                <svg class="action-icon" viewBox="0 0 24 24" fill="${post.liked?'currentColor':'none'}" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                                <span>${post.likes}</span>
                            </button>
                            <button class="action-btn ${post.reposted?'reposted':''}" data-action="repost" data-id="${post.id}">
                                <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"></polyline><path d="M3 11V9a4 4 0 0 1 4-4h14"></path><polyline points="7 23 3 19 7 15"></polyline><path d="M21 13v2a4 4 0 0 1-4 4H3"></path></svg>
                                <span>${post.reposts}</span>
                            </button>
                            <button class="action-btn" data-action="comment" data-id="${post.id}">
                                <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                                <span>${post.comments}</span>
                            </button>
                            <button class="action-btn" data-action="share" data-id="${post.id}">
                                <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                            </button>
                        </div>
                    </div>
                </div>
            </div>`;
        renderComments();
        postModal.style.display = 'flex';
        setTimeout(() => { postModal.classList.add('active'); document.body.style.overflow = 'hidden'; }, 10);
    }

    function closePostModal() {
        postModal.classList.remove('active');
        document.body.style.overflow = '';
        setTimeout(() => { postModal.style.display = 'none'; }, 400);
    }
    document.getElementById('post-modal-close').addEventListener('click', closePostModal);
    postModal.addEventListener('click', e => { if (e.target === postModal) closePostModal(); });

    // ===== COMMENTS =====
    function renderComments() {
        commentsList.innerHTML = '';
        const comments = postComments[currentPostId] || [];
        if (!comments.length) {
            commentsList.innerHTML = '<div class="empty-comments">Здесь пока нет комментариев. Будьте первым!</div>';
            return;
        }
        function makeHTML(c, nested = false) {
            return `<div class="comment-item${nested?' nested-reply':''}" id="comment-${c.id}">
                <div class="comment-avatar"${nested?' style="width:26px;height:26px;font-size:10px;"':''}>${c.avatar}</div>
                <div class="comment-content">
                    <div class="comment-header">
                        <span class="comment-author">${c.author}</span>
                        <span class="comment-username">${c.username} · ${c.time}</span>
                    </div>
                    <div class="comment-text">${formatPostText(c.text)}</div>
                    <div class="comment-actions">
                        <button class="comment-action-btn${c.liked?' liked':''}" onclick="toggleCommentLike(${c.id})">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="${c.liked?'currentColor':'none'}" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                            <span>${c.likes}</span>
                        </button>
                        <button class="comment-action-btn" onclick="showReplyForm(${c.id})">Ответить</button>
                    </div>
                    <div class="reply-form" id="reply-form-${c.id}">
                        <textarea class="comment-input" id="reply-input-${c.id}" placeholder="Ответ @${c.username.replace('@','')}"></textarea>
                        <button class="comment-submit" onclick="submitReply(${c.id})">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline></svg>
                        </button>
                    </div>
                    ${!nested && c.replies && c.replies.length ? `<div class="comment-replies-container" id="replies-${c.id}">${c.replies.map(r=>makeHTML(r,true)).join('')}</div>` : ''}
                </div>
            </div>`;
        }
        comments.forEach(c => { commentsList.innerHTML += makeHTML(c); });
    }

    commentInput.addEventListener('input', () => { commentSubmit.disabled = !commentInput.value.trim(); });
    commentSubmit.addEventListener('click', () => {
        const text = commentInput.value.trim();
        if (!text) return;
        if (!postComments[currentPostId]) postComments[currentPostId] = [];
        postComments[currentPostId].unshift({ id: Date.now(), author:"Вы", username:"@username", avatar:"Я", text, time:"Только что", likes:0, liked:false, replies:[] });
        const post = posts.find(p => p.id === currentPostId);
        post.comments++;
        renderPosts(); if (postModal.classList.contains('active')) openPostModal(post);
        commentInput.value = '';
        commentSubmit.disabled = true;
        renderComments();
    });

    // ===== LOGIN SCREEN =====
const USERS_KEY = 'vp_users';
    const SESSION_KEY = 'vp_session';

    function getUsers() {
        try { return JSON.parse(localStorage.getItem(USERS_KEY) || '{}'); } catch(e) { return {}; }
    }
    function saveUsers(u) { try { localStorage.setItem(USERS_KEY, JSON.stringify(u)); } catch(e){} }
    function getSession() { try { return localStorage.getItem(SESSION_KEY); } catch(e){ return null; } }
    function setSession(u) { try { localStorage.setItem(SESSION_KEY, u); } catch(e){} }

    function showLoginScreen() {
        document.getElementById('login-screen').classList.remove('hidden');
    }
    function hideLoginScreen() {
        document.getElementById('login-screen').classList.add('hidden');
    }
    function showMainPanel() {
        document.getElementById('login-main-panel').style.display = 'flex';
        document.getElementById('vpsc-panel').classList.remove('active');
        document.getElementById('reg-panel').classList.remove('active');
        document.getElementById('login-error').textContent = '';
        document.getElementById('vpsc-error').textContent = '';
        document.getElementById('reg-error').textContent = '';
    }
    function showVpscPanel() {
        document.getElementById('login-main-panel').style.display = 'none';
        document.getElementById('vpsc-panel').classList.add('active');
        document.getElementById('reg-panel').classList.remove('active');
        vpscValue = '';
        updateVpscBoxes();
        setTimeout(() => document.getElementById('vpsc-hidden-input').focus(), 100);
    }
    function showRegPanel() {
        document.getElementById('login-main-panel').style.display = 'none';
        document.getElementById('vpsc-panel').classList.remove('active');
        document.getElementById('reg-panel').classList.add('active');
    }

    function doLogin() {
        const u = document.getElementById('login-username').value.trim();
        const p = document.getElementById('login-password').value;
        const err = document.getElementById('login-error');
        if (!u || !p) { err.textContent = 'Введите логин и пароль'; return; }
        const users = getUsers();
        if (!users[u.toLowerCase()]) { err.textContent = 'Пользователь не найден'; return; }
        if (users[u.toLowerCase()].password !== p) { err.textContent = 'Неверный пароль'; return; }
        setSession(u.toLowerCase());
        hideLoginScreen();
    }

    function doVpscLogin() {
        const err = document.getElementById('vpsc-error');
        if (vpscValue.length < 6) { err.textContent = 'Введите 6-значный код'; return; }
        const users = getUsers();
        const found = Object.values(users).find(u => u.vpsc === vpscValue.toUpperCase());
        if (!found) { err.textContent = 'Неверный VPSC-код'; return; }
        setSession(found.username);
        hideLoginScreen();
    }

    function doRegister() {
        const u = document.getElementById('reg-username').value.trim();
        const p = document.getElementById('reg-password').value;
        const p2 = document.getElementById('reg-password2').value;
        const err = document.getElementById('reg-error');
        if (!u) { err.textContent = 'Введите логин'; return; }
        if (u.length < 3) { err.textContent = 'Логин минимум 3 символа'; return; }
        if (!p) { err.textContent = 'Введите пароль'; return; }
        if (p.length < 4) { err.textContent = 'Пароль минимум 4 символа'; return; }
        if (p !== p2) { err.textContent = 'Пароли не совпадают'; return; }
        const users = getUsers();
        if (users[u.toLowerCase()]) { err.textContent = 'Логин уже занят'; return; }
        // Generate VPSC
        const vpsc = Array.from({length:6}, () => 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'[Math.floor(Math.random()*32)]).join('');
        users[u.toLowerCase()] = { username: u.toLowerCase(), password: p, vpsc };
        saveUsers(users);
        setSession(u.toLowerCase());
        hideLoginScreen();
    }

    // VPSC input handling
    let vpscValue = '';
    function updateVpscBoxes() {
        for (let i = 0; i < 6; i++) {
            const box = document.getElementById('vpsc-b' + i);
            box.textContent = vpscValue[i] ? vpscValue[i].toUpperCase() : '';
            box.classList.toggle('active-box', i === vpscValue.length);
        }
    }
    document.getElementById('vpsc-boxes').addEventListener('click', () => {
        document.getElementById('vpsc-hidden-input').focus();
    });
    document.getElementById('vpsc-hidden-input').addEventListener('input', e => {
        vpscValue = e.target.value.replace(/[\x00-\x1f\x7f]/g,'').slice(0,6);
        e.target.value = vpscValue;
        updateVpscBoxes();
    });
    document.getElementById('vpsc-hidden-input').addEventListener('keydown', e => {
        if (e.key === 'Backspace') {
            vpscValue = vpscValue.slice(0, -1);
            document.getElementById('vpsc-hidden-input').value = vpscValue;
            updateVpscBoxes();
        }
        if (e.key === 'Enter') doVpscLogin();
    });
    document.getElementById('login-username').addEventListener('keydown', e => { if(e.key==='Enter') document.getElementById('login-password').focus(); });
    document.getElementById('login-password').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });

    // Check session on load
    (function() {
        const sess = getSession();
        if (!sess) {
            showLoginScreen();
        }
    })();

    window.toggleCommentLike = id => {
        function toggle(list) {
            for (let c of list) {
                if (c.id === id) { c.liked = !c.liked; c.likes += c.liked ? 1 : -1; return true; }
                if (c.replies && toggle(c.replies)) return true;
            }
        }
        toggle(postComments[currentPostId]);
        renderComments();
    };

    window.showReplyForm = id => {
        const form = document.getElementById(`reply-form-${id}`);
        if (form.classList.contains('active')) { form.classList.remove('active'); return; }
        document.querySelectorAll('.reply-form').forEach(f => f.classList.remove('active'));
        form.classList.add('active');
        document.getElementById(`reply-input-${id}`).focus();
    };

    window.submitReply = id => {
        const input = document.getElementById(`reply-input-${id}`);
        const text = input.value.trim();
        if (!text) return;
        // Find the ROOT comment that owns this reply chain, add reply there (flat)
        const comments = postComments[currentPostId];
        function findRoot(list, targetId) {
            for (let c of list) {
                if (c.id === targetId) return c; // clicked on root itself
                if (c.replies) {
                    for (let r of c.replies) {
                        if (r.id === targetId) return c; // clicked on a reply → return root
                    }
                    // deeper search
                    const found = findRoot(c.replies, targetId);
                    if (found) return found;
                }
            }
            return null;
        }
        const rootComment = findRoot(comments, id);
        if (rootComment) {
            rootComment.replies.push({ id:Date.now(), author:"Вы", username:"@username", avatar:"Я", text, time:"Только что", likes:0, liked:false, replies:[] });
