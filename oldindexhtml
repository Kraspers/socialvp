                    <div class="ep-vpsc-label">VPSC</div>
                    <div class="ep-vpsc-code" id="ep-vpsc-code">A7K2M9</div>
                </div>
                <button class="ep-action-btn password" onclick="alert('Смена пароля')">
                    <div class="ep-action-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#30d158" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </div>
                    Изменить пароль
                </button>
                <button class="ep-action-btn danger" onclick="alert('Удаление аккаунта')">
                    <div class="ep-action-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ff453a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    </div>
                    Удалить аккаунт
