        if (profileData.avatarUrl) {
            const pa = document.querySelector('.profile-avatar');
            pa.innerHTML = `<img src="${profileData.avatarUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`;
        }
        if (profileData.bannerUrl) {
            document.querySelector('.profile-cover').style.background = `url('${profileData.bannerUrl}') center/cover no-repeat`;
        }
        // Update all "Вы" posts in feed with new name/username/avatar
        posts.forEach(p => {
            if (p.username === oldUsername || p.author === 'Вы') {
                p.author = profileData.name;
                p.username = profileData.username;
                if (profileData.avatarUrl) p.avatarUrl = profileData.avatarUrl;
            }
        });
        renderPosts();
        closeEditModal();
    }

    function copyVPSC() {
        try { if (navigator.clipboard && navigator.clipboard.writeText) { navigator.clipboard.writeText(profileData.vpsc).catch(()=>{}); } else { const ta = document.createElement('textarea'); ta.value = profileData.vpsc; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); } } catch(e) {}
        const card = document.querySelector('.ep-vpsc-card');
        if (card) { card.style.background = '#0265d4'; setTimeout(() => { card.style.background = ''; }, 400); }
        const toast = document.getElementById('copy-toast');
        if (toast) { toast.classList.add('show'); clearTimeout(toast._t); toast._t = setTimeout(() => toast.classList.remove('show'), 2000); }
    }

    function triggerCrop(mode) {
        cropMode = mode;
        document.getElementById('ep-file-input').click();
    }

    function onFileSelected(e) {
        const file = e.target.files[0];
        if (!file) return;
        e.target.value = '';
        const reader = new FileReader();
        reader.onload = ev => openCropModal(ev.target.result);
        reader.readAsDataURL(file);
    }

    function openCropModal(src) {
        const modal = document.getElementById('crop-modal');
        const canvas = document.getElementById('crop-canvas');
        const wrap = document.getElementById('crop-canvas-wrap');
        const titleEl = document.getElementById('crop-title');
        cropZoom = 1;
        cropOffsetX = 0; cropOffsetY = 0;
        document.getElementById('crop-zoom-range').value = 1;

        const isAvatar = cropMode === 'avatar';
        const W = isAvatar ? 280 : 320;
        const H = isAvatar ? 280 : 160;
        canvas.width = W; canvas.height = H;
        wrap.classList.toggle('avatar-shape', isAvatar);
        titleEl.textContent = isAvatar ? 'Настройте аватар' : 'Настройте баннер';

        cropImage = new Image();
        cropImage.onload = () => {
            cropNaturalW = cropImage.naturalWidth;
            cropNaturalH = cropImage.naturalHeight;
            // Auto-fit
            const scaleW = W / cropNaturalW;
            const scaleH = H / cropNaturalH;
            cropZoom = Math.max(scaleW, scaleH);
            document.getElementById('crop-zoom-range').min = cropZoom;
            document.getElementById('crop-zoom-range').max = cropZoom * 3;
            document.getElementById('crop-zoom-range').value = cropZoom;
            cropOffsetX = (W - cropNaturalW * cropZoom) / 2;
            cropOffsetY = (H - cropNaturalH * cropZoom) / 2;
            drawCrop();
        };
        cropImage.src = src;
        modal.classList.add('active');
    }

    function drawCrop() {
        const canvas = document.getElementById('crop-canvas');
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(cropImage, cropOffsetX, cropOffsetY, cropNaturalW * cropZoom, cropNaturalH * cropZoom);
    }

    function updateCropZoom(val) {
        const canvas = document.getElementById('crop-canvas');
        const prevZoom = cropZoom;
        cropZoom = parseFloat(val);
        // Zoom toward center
        cropOffsetX = canvas.width/2 - (canvas.width/2 - cropOffsetX) * (cropZoom / prevZoom);
        cropOffsetY = canvas.height/2 - (canvas.height/2 - cropOffsetY) * (cropZoom / prevZoom);
        drawCrop();
    }

    function closeCropModal() {
        document.getElementById('crop-modal').classList.remove('active');
    }

    function confirmCrop() {
        const canvas = document.getElementById('crop-canvas');
        const dataUrl = canvas.toDataURL('image/jpeg', 0.92);
        if (cropMode === 'avatar') {
            profileData.avatarUrl = dataUrl;
            const img = document.getElementById('ep-avatar-img');
            img.src = dataUrl; img.classList.add('loaded');
            document.getElementById('ep-avatar-letter').style.display = 'none';
        } else {
            profileData.bannerUrl = dataUrl;
            const img = document.getElementById('ep-banner-img');
            img.src = dataUrl; img.classList.add('loaded');
        }
        closeCropModal();
    }

    // Crop drag — mouse
    const cropWrap = document.getElementById('crop-canvas-wrap');
    cropWrap.addEventListener('mousedown', e => {
        cropDragging = true; cropStartX = e.clientX - cropOffsetX; cropStartY = e.clientY - cropOffsetY;
        cropWrap.style.cursor = 'grabbing';
    });
    document.addEventListener('mousemove', e => {
        if (!cropDragging) return;
        cropOffsetX = e.clientX - cropStartX; cropOffsetY = e.clientY - cropStartY;
        drawCrop();
    });
    document.addEventListener('mouseup', () => { cropDragging = false; cropWrap.style.cursor = 'grab'; });

    // Crop drag — touch
    cropWrap.addEventListener('touchstart', e => {
        const t = e.touches[0];
        cropDragging = true; cropStartX = t.clientX - cropOffsetX; cropStartY = t.clientY - cropOffsetY;
    }, {passive:true});
    cropWrap.addEventListener('touchmove', e => {
        if (!cropDragging) return;
        const t = e.touches[0];
        cropOffsetX = t.clientX - cropStartX; cropOffsetY = t.clientY - cropStartY;
        drawCrop();
    }, {passive:true});
    cropWrap.addEventListener('touchend', () => { cropDragging = false; });

    document.querySelector('.edit-profile-btn').addEventListener('click', openEditModal);

    // ===== FULLSCREEN PHOTO VIEWER =====
    let pvMedia = [], pvIndex = 0;
    function openPhotoViewer(mediaArr, startIndex) {
        pvMedia = mediaArr; pvIndex = startIndex;
        renderPV();
        document.getElementById('photo-viewer').classList.add('active');
        document.body.style.overflow = 'hidden';
    }
    function closePhotoViewer() {
        document.getElementById('photo-viewer').classList.remove('active');
        document.body.style.overflow = '';
    }
    function pvNav(dir) {
        pvIndex = Math.max(0, Math.min(pvMedia.length - 1, pvIndex + dir));
        renderPV();
    }
    function renderPV() {
        const m = pvMedia[pvIndex];
        const content = document.getElementById('pv-content');
        if (m.type === 'video') {
            content.innerHTML = `<video class="photo-viewer-video" src="${m.src}" controls autoplay></video>`;
        } else {
            content.innerHTML = `<img class="photo-viewer-img" src="${m.src}" alt="">`;
        }
        document.getElementById('pv-counter').textContent = pvMedia.length > 1 ? (pvIndex+1) + ' / ' + pvMedia.length : '';
        document.getElementById('pv-prev').disabled = pvIndex === 0;
        document.getElementById('pv-next').disabled = pvIndex === pvMedia.length - 1;
    }
    // Click on post media item
    document.addEventListener('click', e => {
        const item = e.target.closest('.post-media-item');
        if (!item) return;
        const grid = item.closest('.post-media-grid');
        if (!grid) return;
        const items = Array.from(grid.querySelectorAll('.post-media-item'));
        const idx = items.indexOf(item);
        // Collect media from grid
        const mediaArr = items.map(el => {
            const img = el.querySelector('img');
            const vid = el.querySelector('video');
            return img ? {type:'image', src:img.src} : {type:'video', src:vid.src};
        });
        openPhotoViewer(mediaArr, idx);
    });
    // Close on backdrop click
    document.getElementById('photo-viewer').addEventListener('click', e => {
        if (e.target === document.getElementById('photo-viewer') || e.target === document.getElementById('pv-content'))
            closePhotoViewer();
    });
    // Keyboard nav
    document.addEventListener('keydown', e => {
        if (!document.getElementById('photo-viewer').classList.contains('active')) return;
        if (e.key === 'ArrowLeft') pvNav(-1);
        if (e.key === 'ArrowRight') pvNav(1);
        if (e.key === 'Escape') closePhotoViewer();
    });

</script>

</body>
</html>