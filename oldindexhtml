<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VP 2.0</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: sans-serif; background: #0b0b0d; color: #e6e6e9; }
        .container { max-width: 600px; margin: 0 auto; background: #0f0f11; min-height: 100vh; border: 1px solid rgba(255,255,255,0.04); position: relative; }
        .header { display: flex; align-items: center; padding: 12px 16px; background: rgba(10,10,10,0.55); backdrop-filter: blur(12px) saturate(180%); -webkit-backdrop-filter: blur(12px) saturate(180%); border-bottom: 1px solid rgba(255,255,255,0.04); position: sticky; top: 0; z-index: 100; }
        .logo-container { display: flex; align-items: center; justify-content: center; width: 100%; }
        .logo { height: 50px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: transparent; padding: 6px 10px; border-radius: 8px; }
        .logo img { height: 100%; width: auto; object-fit: contain; }
        .stories-container { padding: 16px; border-bottom: 8px solid rgba(255,255,255,0.02); overflow-x: auto; overflow-y: hidden; white-space: nowrap; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
        .stories-container::-webkit-scrollbar { display: none; }
        .stories-list { display: inline-flex; gap: 12px; }
        .story-item { display: flex; flex-direction: column; align-items: center; gap: 6px; cursor: pointer; }
        .story-avatar { width: 64px; height: 64px; border-radius: 50%; padding: 3px; background: linear-gradient(45deg, #0D7EFF 0%, #4A9FFF 50%, #0A5FCC 100%); background-size: 200% 200%; animation: gradientShift 3s ease infinite; display: flex; align-items: center; justify-content: center; }
        @keyframes gradientShift { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
        .story-avatar.create { background: transparent; animation: none; }
        .story-avatar-inner { width: 56px; height: 56px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center; overflow: hidden; }
        .story-avatar.create .story-avatar-inner { background: transparent; }
        .story-avatar-img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
        .story-username { font-size: 12px; color: rgba(255,255,255,0.7); max-width: 64px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .story-viewer { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: #000; z-index: 9999; display: none; flex-direction: column; user-select: none; -webkit-user-select: none; -webkit-touch-callout: none; }
        .story-viewer.active { display: flex; }
        .story-header { position: absolute; top: 0; left: 0; right: 0; z-index: 2; padding: 16px; background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 100%); }
        .story-progress-bars { display: flex; gap: 4px; margin-bottom: 12px; }
        .story-progress-bar { flex: 1; height: 2px; background: rgba(255,255,255,0.3); border-radius: 1px; overflow: hidden; }
        .story-progress-fill { height: 100%; background: white; width: 0%; transition: width 0.1s linear; }
        .story-user-info { display: flex; align-items: center; gap: 12px; }
        .story-user-avatar { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 14px; font-weight: 600; }
        .story-user-name { color: white; font-weight: 600; font-size: 14px; }
        .story-user-time { color: rgba(255,255,255,0.7); font-size: 12px; margin-left: 8px; }
        .story-close-btn { margin-left: auto; background: none; border: none; color: white; font-size: 28px; cursor: pointer; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; }
        .story-content { flex: 1; display: flex; align-items: center; justify-content: center; max-width: 600px; margin: 0 auto; width: 100%; }
        .story-media { max-width: 100%; max-height: 100vh; object-fit: contain; }
        .story-nav { position: absolute; top: 0; bottom: 0; width: 50%; cursor: pointer; z-index: 1; }
        .story-nav.prev { left: 0; }
        .story-nav.next { right: 0; }
        .story-creator {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.8);
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .story-creator.active { display: flex; }
        .story-creator.visible { opacity: 1; }
        .story-creator-inner {
            width: 100%; max-width: 500px; height: 80vh;
            background: #000; border-radius: 20px;
            display: flex; flex-direction: column; overflow: hidden; position: relative;
            transform: translateY(0);
            transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);
        }
        .story-creator.active .story-creator-inner { border: 2px solid rgba(255,255,255,0.101); }
        /* Mobile: slide up from bottom */
        @media (max-width: 600px) {
            .story-creator { align-items: flex-end; }
            .story-creator-inner {
                height: 92vh; max-width: 100%;
                border-radius: 20px 20px 0 0;
                transform: translateY(100%);
            }
            .story-creator.visible .story-creator-inner { transform: translateY(0); }
        }
        /* Desktop: just fade, no slide */
        @media (min-width: 601px) {
            .story-creator-inner { transform: scale(0.96); opacity: 0; transition: transform 0.3s ease, opacity 0.3s ease; }
            .story-creator.visible .story-creator-inner { transform: scale(1); opacity: 1; }
        }
        .creator-header { padding: 16px; display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.5); }
        .creator-close { background: none; border: none; color: white; font-size: 28px; cursor: pointer; }
        .creator-title { color: white; font-weight: 600; font-size: 16px; }
        .creator-done { background: #0D7EFF; color: white; border: none; padding: 8px 20px; border-radius: 20px; font-weight: 600; cursor: pointer; }
        .creator-content { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20px; padding: 20px; }
        .creator-preview { max-width: 100%; max-height: 60vh; object-fit: contain; display: none; }
        .creator-preview.active { display: block; }
        .creator-options { display: flex; gap: 20px; }
        .creator-option { display: flex; flex-direction: column; align-items: center; gap: 8px; cursor: pointer; }
        .creator-option-icon { width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; font-size: 28px; color: white; }
        .creator-option-label { color: white; font-size: 14px; }
        .creator-input { display: none; }
        .post-composer { padding: 16px; border-bottom: 8px solid rgba(255,255,255,0.02); }
        .composer-container { position: relative; border: 1px solid rgba(255,255,255,0.04); border-radius: 16px; padding: 16px; background: rgba(255,255,255,0.02); transition: border-color 0.25s cubic-bezier(0.16,1,0.3,1); }
        .composer-container:focus-within { border-color: #0D7EFF; }
        .composer-input { width: 100%; min-height: 150px; border: none; padding: 0; font-size: 16px; resize: none; font-family: inherit; outline: none; background: transparent; color: #e6e6e9; }
        .composer-input::placeholder { color: rgba(255,255,255,0.5); }
        .composer-actions { display: flex; justify-content: space-between; align-items: center; margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.03); }
        .media-btn { width: 40px; height: 40px; border: none; background: transparent; border-radius: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; color: #0D7EFF; }
        .media-btn:hover { background: rgba(255,255,255,0.03); }
        .post-btn-container { display: flex; align-items: center; gap: 12px; }
        .char-counter { font-size: 14px; color: rgba(255,255,255,0.6); opacity: 0; transition: opacity 0.2s; }
        .char-counter.visible { opacity: 1; }
        .char-counter.warning { color: #ff9500; }
        .char-counter.danger { color: #ff3b30; }
        .composer-container.shake { animation: shake 0.5s ease-in-out; border-color: #ff3b30 !important; }
        @keyframes shake { 0%,100% { transform: translateX(0) scale(1); } 15%,45%,75% { transform: translateX(-6px) scale(1.015); } 30%,60%,90% { transform: translateX(6px) scale(1.015); } }
        .post-btn { width: 40px; height: 40px; background: #0D7EFF; color: white; border: none; border-radius: 50%; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; }
        .post-btn:hover { background: #0066dd; transform: scale(1.05); }
        .post-btn:disabled { background: rgba(13,126,255,0.3); cursor: not-allowed; transform: scale(1); }
        .feed { padding: 16px; padding-bottom: 100px; }
        .post { padding: 16px; background: rgba(255,255,255,0.02); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); border-radius: 16px; margin-bottom: 12px; border: 1px solid rgba(255,255,255,0.04); transition: border-color 0.2s; overflow: hidden; }
        .post:hover { border-color: rgba(255,255,255,0.08); }
        .post-header { display: flex; align-items: flex-start; gap: 12px; }
        .avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 18px; }
        .post-content { flex: 1; min-width: 0; }
        .post-author { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
        .author-name { font-weight: 600; font-size: 15px; }
        .author-username { color: rgba(255,255,255,0.6); font-size: 15px; }
        .post-time { color: rgba(255,255,255,0.6); font-size: 15px; }
        .post-text { font-size: 15px; line-height: 1.5; margin: 8px 0; word-wrap: break-word; }
        .hashtag { color: #0D7EFF; cursor: pointer; }
        .mention { color: #0D7EFF; cursor: pointer; }
        .post-actions { display: flex; gap: 24px; margin-top: 12px; padding-top: 4px; margin-left: -24px; }
        .action-btn { display: flex; align-items: center; gap: 8px; background: none; border: none; color: rgba(255,255,255,0.75); cursor: pointer; font-size: 14px; transition: all 0.2s; padding: 8px 12px; border-radius: 8px; }
        .action-btn:hover { background: rgba(255,255,255,0.02); color: #0D7EFF; }
        .action-btn.liked { color: #ff3b30; }
        .action-btn.liked:hover { background: #ffe6e6; }
        .action-btn.reposted { color: #34c759; }
        .action-btn.reposted:hover { background: #e6f7ed; }
        .action-icon { width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; }
        .bottom-nav { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); width: 280px; background: rgba(10,10,10,0.6); backdrop-filter: blur(12px) saturate(180%); -webkit-backdrop-filter: blur(12px) saturate(180%); border: 1px solid rgba(255,255,255,0.06); border-radius: 35px; display: flex; justify-content: space-between; align-items: center; padding: 10px; box-shadow: 0 8px 24px rgba(0,0,0,0.35); z-index: 1000; }
        .nav-slider { position: absolute; height: 50px; width: 80px; background: rgba(13,126,255,0.15); border-radius: 25px; transition: transform 0.4s cubic-bezier(0.16,1,0.3,1); left: 10px; top: 10px; z-index: 0; }
        .nav-btn { background: none; border: none; cursor: pointer; padding: 15px; display: flex; align-items: center; justify-content: center; color: #bfbfbf; transition: all 0.3s; font-size: 24px; width: 80px; height: 50px; position: relative; z-index: 1; }
        .nav-btn.active { color: #0D7EFF; }
        .nav-btn:hover:not(.active) { color: #0D7EFF; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .search-bar { padding: 16px; background: transparent; border-bottom: 1px solid rgba(255,255,255,0.04); }
        .search-input { width: 100%; padding: 12px 16px; border: 1px solid rgba(255,255,255,0.04); border-radius: 20px; font-size: 15px; background: rgba(255,255,255,0.02); color: #e6e6e9; }
        .search-input::placeholder { color: rgba(255,255,255,0.5); }
        .search-input:focus { outline: none; background: rgba(255,255,255,0.03); border-color: #0D7EFF; }
        .trends-section { padding: 16px; }
        .section-title { font-size: 20px; font-weight: 700; margin-bottom: 16px; }
        .trend-item { padding: 12px 8px; border-bottom: 1px solid rgba(255,255,255,0.04); cursor: pointer; border-radius: 8px; transition: background 0.2s; }
        .trend-item:hover { background: rgba(255,255,255,0.02); }
        .trend-category { font-size: 13px; color: rgba(255,255,255,0.6); }
        .trend-hashtag { font-size: 15px; font-weight: 600; margin: 4px 0; }
        .trend-count { font-size: 13px; color: rgba(255,255,255,0.6); }
        .notification-item { display: flex; gap: 12px; padding: 16px; border-bottom: 1px solid rgba(255,255,255,0.04); cursor: pointer; }
        .notification-icon { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; }
        .notification-icon.like { background: #ffe6e6; color: #ff3b30; }
        .notification-icon.repost { background: #e6f7ed; color: #34c759; }
        .notification-icon.comment { background: #e6f0ff; color: #0D7EFF; }
        .notification-icon.follow { background: #f3e6ff; color: #af52de; }
        .notification-text { flex: 1; font-size: 15px; line-height: 1.4; }
        .notification-time { font-size: 13px; color: rgba(255,255,255,0.6); margin-top: 4px; }
        /* ===== LOGIN SCREEN ===== */
        .login-screen {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: #0b0b0d; z-index: 19000;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            padding: 0 32px; transition: opacity 0.5s cubic-bezier(0.16,1,0.3,1), visibility 0.5s cubic-bezier(0.16,1,0.3,1);
            overflow-y: auto;
        }
        .login-screen.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
        .login-logo-wrap {
            display: flex; align-items: center; gap: 14px; margin-bottom: 52px;
        }
        .login-logo-img {
            width: 200px; height: 200px; object-fit: contain; border-radius: 20px;
        }
        .login-logo-text {
            font-size: 28px; font-weight: 700; color: white; letter-spacing: -0.5px;
        }
        .login-input {
            width: 100%; max-width: 380px; box-sizing: border-box;
            background: #2a2a2e; border: none; outline: none;
            border-radius: 18px; color: white; font-size: 17px;
            font-family: inherit; padding: 20px 22px; margin-bottom: 14px;
            -webkit-appearance: none;
        }
        .login-input::placeholder { color: rgba(255,255,255,0.35); }
        .login-input:focus { background: #333338; }
        .login-btn-white {
            width: 100%; max-width: 380px; box-sizing: border-box;
            background: white; border: none; border-radius: 18px;
            color: #000; font-size: 18px; font-weight: 700;
            font-family: inherit; padding: 20px; cursor: pointer;
            margin-top: 10px; margin-bottom: 14px; -webkit-appearance: none;
            transition: transform 0.2s cubic-bezier(0.16,1,0.3,1), opacity 0.2s;
        }
        .login-btn-white:active { transform: scale(0.97); opacity: 0.9; }
        .login-btn-blue {
            width: 100%; max-width: 380px; box-sizing: border-box;
            background: #1877f2; border: none; border-radius: 18px;
            color: white; font-size: 18px; font-weight: 700;
            font-family: inherit; padding: 0; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            height: 64px;
            margin-bottom: 18px; -webkit-appearance: none;
            transition: transform 0.2s cubic-bezier(0.16,1,0.3,1), opacity 0.2s;
            overflow: hidden; position: relative;
        }
        .login-btn-blue:active { transform: scale(0.97); opacity: 0.9; }
        .login-btn-blue svg { flex-shrink: 0; }
        .login-reg-link {
            color: rgba(255,255,255,0.4); font-size: 15px; font-weight: 500;
            cursor: pointer; background: none; border: none;
            font-family: inherit; padding: 8px 0;
        }
        .login-error {
            color: #ff4545; font-size: 14px; text-align: center;
            margin-bottom: 10px; min-height: 18px; max-width: 380px; width: 100%;
        }
        /* VPSC panel */
        .vpsc-panel {
            width: 100%; max-width: 380px; display: none; flex-direction: column; align-items: center;
        }
        .vpsc-panel.active { display: flex; }
        .vpsc-title {
            color: white; font-size: 20px; font-weight: 700;
            margin-bottom: 6px; text-align: center;
        }
        .vpsc-subtitle {
            color: rgba(255,255,255,0.4); font-size: 14px; margin-bottom: 24px; text-align: center;
        }
        .vpsc-boxes {
            display: flex; gap: 10px; margin-bottom: 24px; position: relative;
        }
        .vpsc-box {
            width: 50px; height: 60px;
            background: #2a2a2e; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; font-weight: 700; color: white;
            cursor: pointer; border: 2px solid transparent;
            transition: border-color 0.2s;
        }
        .vpsc-box.active-box { border-color: #1877f2; }
        .vpsc-input-hidden {
            position: fixed; opacity: 0; pointer-events: none; width: 1px; height: 1px;
            top: -9999px; left: -9999px;
        }
        /* Register panel */
        .reg-panel {
            width: 100%; max-width: 380px; display: none; flex-direction: column; align-items: center;
        }
        .reg-panel.active { display: flex; }
        .reg-title {
            color: white; font-size: 24px; font-weight: 700;
            margin-bottom: 24px; text-align: center; width: 100%;
        }
        .login-back-btn {
            color: rgba(255,255,255,0.4); font-size: 14px; cursor: pointer;
            background: none; border: none; font-family: inherit;
            margin-bottom: 20px; align-self: flex-start; padding: 0;
        }

        .splash-screen { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: #0b0b0d; z-index: 20000; display: flex; flex-direction: column; align-items: center; justify-content: center; transition: opacity 0.5s ease, visibility 0.5s; }
        .splash-screen.hidden { opacity: 0; visibility: hidden; }
        .splash-logo { width: 120px; height: 120px; object-fit: contain; margin-bottom: 20px; animation: splashPulse 1.5s ease-in-out infinite; }
        @keyframes splashPulse { 0% { transform: scale(1); opacity: 0.8; } 50% { transform: scale(1.1); opacity: 1; } 100% { transform: scale(1); opacity: 0.8; } }
        .post-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.85); z-index: 10000; display: none; align-items: center; justify-content: center; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); opacity: 0; transition: opacity 0.3s ease; }
        .post-modal.active { display: flex; opacity: 1; }
        .post-modal-content { background: #0f0f11; width: 100%; max-width: 600px; height: 100%; max-height: 100vh; position: relative; display: flex; flex-direction: column; transform: translateY(100%); transition: transform 0.5s cubic-bezier(0.16,1,0.3,1); border-left: 1px solid rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.05); }
        .post-modal.active .post-modal-content { transform: translateY(0); }
        .post-modal-header { padding: 12px 16px; display: flex; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(15,15,17,0.8); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 2; }
        .post-modal-close { background: none; border: none; color: white; font-size: 24px; cursor: pointer; padding: 8px; margin-right: 16px; display: flex; align-items: center; justify-content: center; }
        .post-modal-body { flex: 1; overflow-y: auto; padding: 16px; }
        .post-modal .post { background: transparent; border: none; padding: 0; margin: 0; backdrop-filter: none; }
        .post-modal .post-actions { margin-left: 0; justify-content: space-around; border-top: 1px solid rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 12px 0; margin-top: 20px; }
        .comment-form { display: flex; gap: 12px; padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .comment-input-container { flex: 1; }

        /* Smaller, rounder inputs */
        .comment-input { width: 100%; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 20px; padding: 5px 14px; color: white; font-family: inherit; font-size: 14px; outline: none; resize: none; height: 32px; min-height: 32px; max-height: 100px; overflow: hidden; transition: border-color 0.2s, height 0.1s; line-height: 22px; display: block; word-wrap: break-word; }
        .comment-input:focus { border-color: #0D7EFF; height: auto; min-height: 32px; overflow: auto; }
        .comment-submit { width: 34px; height: 34px; background: #0D7EFF; color: white; border: none; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; flex-shrink: 0; }
        .comment-submit svg { width: 16px; height: 16px; }
        .comment-submit:hover { background: #0066dd; transform: scale(1.05); }
        .comment-submit:disabled { background: rgba(13,126,255,0.3); cursor: not-allowed; transform: scale(1); }
        .comments-list { margin-top: 16px; }
        .comment-item { display: flex; gap: 12px; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.03); }
        .comment-avatar { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 13px; flex-shrink: 0; }
        .comment-content { flex: 1; min-width: 0; }
        .comment-header { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; flex-wrap: wrap; }
        .comment-author { font-weight: 600; font-size: 14px; }
        .comment-username { color: rgba(255,255,255,0.5); font-size: 12px; }
        .comment-text { font-size: 14px; line-height: 1.4; margin-bottom: 6px; word-wrap: break-word; }
        .comment-actions { display: flex; gap: 16px; }
        .comment-action-btn { background: none; border: none; color: rgba(255,255,255,0.5); cursor: pointer; font-size: 12px; display: flex; align-items: center; gap: 4px; padding: 0; }
        .comment-action-btn:hover { color: #0D7EFF; }
        .comment-action-btn.liked { color: #ff3b30; }

        /* FIX: replies stack vertically, no sideways overflow — cap indent at 1 level */
